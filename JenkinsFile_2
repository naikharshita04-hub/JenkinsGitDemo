pipeline{
agent any
  stages{
    stage('Checkout'){
      steps{
        git 'https://github.com/naikharshita04-hub/JenkinsGitDemo.git'
       }
    }
    stage('Publish'){
      steps{
      publishHTML([
        allowMissing:true,
        alwaysLinkToLastBuild:false,
        KeepAll:false,
        reportDir:'.',
        reportFiles:'index.html',  
        reportName:'My HTML Page',
        ])
    }
  }
  }
}
